PORT=3001

# Required: at least set OPENWEATHERMAP_API_KEY to get multi-source consensus
# Open-Meteo works with NO key and is always active
OPENWEATHERMAP_API_KEY=your_key_here   # free: 1,000 calls/day at openweathermap.org
TOMORROW_IO_API_KEY=your_key_here      # free: 500 calls/day at tomorrow.io
WEATHERAPI_KEY=your_key_here           # free: 1M calls/month at weatherapi.com

CACHE_TTL_SECONDS=600
DISPUTE_THRESHOLD_CELSIUS=3
