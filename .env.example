PORT=3001

# Your deployed app's public URL (used by digest email links and internal cron calls)
# e.g. https://weather.yourdomain.com
# Falls back to http://localhost:3001 when not set (fine for local dev)
APP_URL=

# --- Weather API keys (all optional — Open-Meteo needs no key and is always on) ---
OPENWEATHERMAP_API_KEY=   # free: 1,000 calls/day   — openweathermap.org
TOMORROW_IO_API_KEY=      # free: 500 calls/day     — tomorrow.io
WEATHERAPI_KEY=           # free: 1M calls/month    — weatherapi.com
PIRATE_WEATHER_API_KEY=   # free: 20,000 calls/month — pirateweather.net (Dark Sky successor; adds minutely precip + Canada/UK coverage)

# --- AI chat (optional — AI endpoint returns 503 if not set) ---
GROQ_API_KEY=             # free tier — console.groq.com

# --- Database (optional — enables accuracy tracking + adaptive source weights) ---
DATABASE_URL=postgresql://user:password@host:5432/weatherwise
DATABASE_SSL=false        # set to true for hosted Postgres (Railway, Render, Supabase, etc.)

# --- Email digest (optional — digest emails logged to console if not set) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false         # set to true for TLS connections (port 465)
EMAIL_FROM=               # defaults to SMTP_USER if blank

# --- Auth (generate a random secret: openssl rand -hex 32) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Analytics (client-side, add to Render environment variables) ---
# VITE_POSTHOG_KEY=         # free up to 1M events/month — posthog.com

# --- User accounts (client-side + server-side, add to Render environment variables) ---
# VITE_CLERK_PUBLISHABLE_KEY=   # free up to 10k MAU — clerk.com
# CLERK_SECRET_KEY=              # from the same Clerk dashboard

# --- Tuning ---
CACHE_TTL_SECONDS=600           # seconds to cache weather API responses
DISPUTE_THRESHOLD_CELSIUS=3     # min °C spread between sources to show dispute badge

# --- Development only (remove in production) ---
# NODE_TLS_REJECT_UNAUTHORIZED=0   # disable TLS validation for local self-signed certs
