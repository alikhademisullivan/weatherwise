PORT=3001

# Your deployed app's public URL (used by digest email links and internal cron calls)
# e.g. https://weather.yourdomain.com
APP_URL=

# --- Weather API keys (all optional except Open-Meteo which needs no key) ---
OPENWEATHERMAP_API_KEY=   # free: 1,000 calls/day — openweathermap.org
TOMORROW_IO_API_KEY=      # free: 500 calls/day — tomorrow.io
WEATHERAPI_KEY=           # free: 1M calls/month — weatherapi.com

# --- AI chat ---
GROQ_API_KEY=             # free tier — console.groq.com

# --- Database (optional — enables accuracy tracking + adaptive weights) ---
DATABASE_URL=postgresql://user:password@host:5432/weatherwise
DATABASE_SSL=true         # set to true for hosted Postgres (Railway, Render, Supabase, etc.)

# --- Email digest (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=

# --- Auth (generate a random secret: openssl rand -hex 32) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Analytics (client-side, add to Render environment variables) ---
# VITE_POSTHOG_KEY=         # free up to 1M events/month — posthog.com

# --- User accounts (client-side + server-side, add to Render environment variables) ---
# VITE_CLERK_PUBLISHABLE_KEY=   # free up to 10k MAU — clerk.com
# CLERK_SECRET_KEY=              # from the same Clerk dashboard

# --- Tuning ---
CACHE_TTL_SECONDS=600
DISPUTE_THRESHOLD_CELSIUS=3
